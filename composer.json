{
    "name": "andydefer/laravel-nemesis",
    "description": "Nemesis: Multi-model token-based authentication for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AndyDefer\\Nemesis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\Nemesis\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\Nemesis\\NemesisServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/laravel-repository": "^2.10.8",
        "andydefer/data-validator": "^1.0.3",
        "andydefer/laravel-actions": "^2.4.11",
        "andydefer/laravel-directive": "^3.56.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "larastan/larastan": "^3.8",
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.8",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "symfony/var-dumper": "^7.0",
        "vimeo/psalm": "^6.14",
        "andydefer/dev-tools": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../dev-tools",
            "options": {
                "symlink": true
            }
        }
    ]
}
